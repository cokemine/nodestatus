{
  "name": "nodestatus-server",
  "type": "module",
  "version": "1.2.9-beta",
  "author": "Kagurazaka Mizuki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cokemine/nodestatus.git",
    "directory": "packages/nodestatus-server"
  },
  "main": "index.js",
  "bin": {
    "status-server": "bin/status-server.js",
    "status-server-run": "bin/status-server-run.js"
  },
  "files": [
    "bin",
    "build",
    "prisma",
    "scripts"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "dev": "cross-env NODE_ENV=development rolldown -c rolldown.config.mjs --watch",
    "postinstall": "node scripts/init.js",
    "lint": "eslint . --fix",
    "prestart": "node scripts/init.js",
    "start": "node build/app.js",
    "pretest": "cross-env NODE_ENV=TEST node scripts/init.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.0.1",
    "hono": "^4.12.27",
    "mariadb": "^3.4.0",
    "pg": "^8.13.1",
    "prisma": "^7.8.0",
    "replace-in-file": "^6.3.2"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.7"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^10.0.2",
    "@msgpack/msgpack": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ws": "^8.18.0",
    "bcrypt-ts": "^8.0.1",
    "classic-theme": "workspace:*",
    "commander": "^10.0.0",
    "cross-env": "^7.0.3",
    "encoding": "^0.1.13",
    "hotaru-admin": "workspace:*",
    "hotaru-theme": "workspace:*",
    "https-proxy-agent": "^5.0.1",
    "ipaddr.js": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.4.7",
    "telegraf": "^4.16.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "ws": "^8.21.0"
  }
}
